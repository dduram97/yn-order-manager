# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# VPS Aligo API Server (Vercel → VPS, Aligo 키는 VPS에만)
# 예: https://api.your-domain.com 또는 https://your-vps-ip:4000
# ──────────────────────────────────────────────
ALIGO_API_URL=https://your-vps-domain-or-ip

# 발송 payload 구성 (Vercel)
ALIGO_SENDER_PHONE=01012345678
ALIGO_TEST_MODE=N

# Vercel ↔ VPS 공유 시크릿 (선택)
# ALIGO_VPS_SECRET=

# ──────────────────────────────────────────────
# 인증
# ──────────────────────────────────────────────
AUTH_SESSION_SECRET=change-this-to-a-random-secret-at-least-32-chars
